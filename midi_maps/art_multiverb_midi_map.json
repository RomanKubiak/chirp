        "set_bypass.xx.00": "off",
        "set_bypass.xx.01": "on",
        "request_all_presets": "F0 1A 0x 05 4B F7",
        "load_all_presets": "F0 1A 0x 05 0B <200x29_bytes> F7",
        "request_mpt": "F0 1A 0x 05 40 F7",
        "set_mpt": "F0 1A 0x 05 0C <128x2_bytes> F7"
      }
    },
    "mpt": {
      "entry_size_bytes": "2",
      "entry_encoding": "lsb_7bit_then_msb",
      "midi_program_0": "user_assignable",
      "midi_program_127": "user_assignable"
    }
  },
  "notes": {
    "1": "Manual does not provide a TR-style CC-per-parameter controller table.",
    "2": "MIDI implementation centers on Program Change + MPT + SysEx dumps/commands.",
    "3": "Use front-panel utility for send_preset, send_mpt, send_all_presets."
  }
